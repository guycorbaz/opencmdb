# opencmdb configuration — COPY this to `.env` and fill it in. The real `.env` is git-ignored.
#
# Use ONLY placeholders in this committed template: RFC 5737 documentation addresses
# (192.0.2.0/24) and CHANGE_ME. No real hostnames, passwords, tokens, or NAS paths — those
# live only on the NAS, never in the repository.

# ── Database — your EXISTING MariaDB ─────────────────────────────────────────────────────────
#
# FIRST: provision it yourself. Nothing in the compose file creates the database, the user or
# the grants. On your MariaDB, as an administrator:
#
#   CREATE DATABASE opencmdb CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;
#   CREATE USER 'opencmdb'@'%' IDENTIFIED BY 'your-password';
#   GRANT ALL PRIVILEGES ON opencmdb.* TO 'opencmdb'@'%';
#   FLUSH PRIVILEGES;
#
# The binary collation is required (identity comparison must never depend on the database's
# locale). Narrow `'%'` to the address opencmdb actually connects FROM once it works — and read
# the next paragraph before guessing what that address is.
#
# The host below is the address of your DATABASE SERVER as seen FROM INSIDE the container. It is
# NOT 127.0.0.1: the container has its own network namespace, so loopback means the container
# itself. Use the LAN address of the machine running MariaDB.
#
# ⚠️ GRANTS MATCH THE ADDRESS THE SERVER SEES, NOT THE ONE YOU DIAL. If authentication fails,
# read the error — `Access denied for user 'opencmdb'@'<host>'` names the exact identity to
# grant. On a multi-homed host these differ: traffic sent to one interface can leave by another,
# and MariaDB matches on the source it observes (or its reverse-resolved name). The tell-tale
# sign is that the host in the error message CHANGES as you change the URL.
#
# ⚠️ A `$` IN THE PASSWORD MUST BE DOUBLED — `$$`. Docker Compose interpolates the contents of
# this file, so `pa$$word` written once as `pa$word` is silently truncated to `pa` and you get an
# opaque "access denied". This happens before opencmdb ever runs, so no amount of URL encoding
# in the application can save you. Measured: `abc$def` arrives as `abc`; `abc$$def` arrives as
# `abc$def`.
#
# ⚠️ URL-RESERVED CHARACTERS MUST BE PERCENT-ENCODED. Separately from the above, the password
# sits inside a URL: `@` → %40, `:` → %3A, `/` → %2F, `#` → %23, `?` → %3F, `%` → %25,
# ` ` → %20. opencmdb percent-decodes the user info, so MariaDB receives the original password.
#
#   e.g. the password  s3cr$t@x  is written  s3cr$$t%40x
#   →  DATABASE_URL=mysql://opencmdb:s3cr$$t%40x@192.0.2.5:3306/opencmdb
DATABASE_URL=mysql://opencmdb:CHANGE_ME@192.0.2.5:3306/opencmdb

# ── HTTP ─────────────────────────────────────────────────────────────────────────────────────
OPENCMDB_BIND=0.0.0.0:8080
OPENCMDB_LOG=info
# UI language: en | fr
OPENCMDB_LOCALE=en

# ── Logging ──────────────────────────────────────────────────────────────────────────────────
# Write daily-rotating file logs (opencmdb.YYYY-MM-DD.log) to this in-container path — the compose
# mounts it from ./log on the host, so files land in docker/log for on-NAS debugging. Leave unset
# to log only to stdout (docker logs). The host ./log must be writable by uid 65532 (nonroot).
OPENCMDB_LOG_DIR=/var/log/opencmdb
# How many daily log files to keep before the oldest is deleted.
OPENCMDB_LOG_RETENTION=14

# ── Startup scan (optional) ──────────────────────────────────────────────────────────────────
# Set to your real LAN CIDR (e.g. 192.168.x.0/24) to ping-scan it on startup and ingest what
# answers. Left as an RFC 5737 documentation range here. Bounded to /22 or smaller.
OPENCMDB_SCAN_CIDR=192.0.2.0/24

# How many probes may be in flight at once (default 64). This is a POLITENESS bound, not a
# throughput one: a ping sends 16 bytes and waits, so the whole scan runs on one thread either
# way, and raising this does not consume more CPU. What it does raise is how hard you hit your
# gateway's ARP table — 1022 simultaneous probes on a /22 is impolite. Lower it on a fragile
# network; set it to 1 to scan strictly one address at a time (slow: a mostly-empty /24 then
# costs about four minutes instead of a few seconds).
# OPENCMDB_SCAN_CONCURRENCY=64

# ── Metrics ──────────────────────────────────────────────────────────────────────────────────
# Bearer token for GET /metrics (Prometheus). Set a real secret, or leave unset to keep /metrics
# closed. Prometheus carries it via `bearer_token` in the scrape config.
OPENCMDB_METRICS_TOKEN=CHANGE_ME

# ── The declared entity the walking-skeleton page reconciles (optional) ──────────────────────
# Pin which declared entity the page shows; otherwise it picks the first one carrying an ipv4.
# OPENCMDB_ENTITY_IPV4=192.0.2.10
